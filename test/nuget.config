<?xml version="1.0" encoding="utf-8"?>
<!--
  Points NuGet restore at the local .nupkg in the repo root so the test project
  can be restored without a nuget.org upload.

  Usage:
    nuget restore test.sln
  or open test.sln in Visual Studio — restore runs automatically.
-->
<configuration>
  <packageSources>
    <add key="local-getUltrafastSecp256k1" value="..\..\" />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" />
  </packageSources>
</configuration>
